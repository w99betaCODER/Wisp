# Wisp panel configuration — copy to /etc/wisp/panel.env
WISP_ADDR=:8080
WISP_DB=/opt/wisp/wisp.db

# How clients reach a node (used to build vless:// subscription links).
WISP_NODE_HOST=vpn.example.com
WISP_NODE_PORT=443
WISP_NODE_FLOW=xtls-rprx-vision
WISP_REALITY_PBK=
WISP_REALITY_SNI=www.microsoft.com
WISP_REALITY_SID=0123456789abcdef
WISP_REALITY_FP=chrome

# mTLS to node agents (from `wisp-certs`). Without these the panel talks to
# nodes over plain HTTP — do not do this in production.
WISP_NODE_TLS_CERT=/etc/wisp/certs/client.crt
WISP_NODE_TLS_KEY=/etc/wisp/certs/client.key
WISP_NODE_TLS_CA=/etc/wisp/certs/ca.crt

# Traffic accounting / quota sweep interval, seconds.
WISP_ENFORCE_INTERVAL=60
