# Wisp node agent configuration — copy to /etc/wisp/node.env
WISP_AGENT_LISTEN=:8443
WISP_XRAY_API=127.0.0.1:10085
WISP_INBOUND_TAG=vless-reality

# mTLS server material (from `wisp-certs`). Without these the agent serves
# plain HTTP — do not do this in production.
WISP_TLS_CERT=/etc/wisp/certs/server.crt
WISP_TLS_KEY=/etc/wisp/certs/server.key
WISP_TLS_CLIENT_CA=/etc/wisp/certs/ca.crt
